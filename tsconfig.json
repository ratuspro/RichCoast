{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Phaser extends classes via prototype/constructor assignment; defining
       class fields with [[Define]] semantics shadows inherited members with
       `undefined`. Keep this false for any Phaser project. */
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Strictness — the seam and the gameplay both lean on this. Intentionally
       unused seam params/locals are marked with a leading underscore. */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
